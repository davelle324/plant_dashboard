DATABASE_URL=sqlite:///./plants.db
# Comma-separated list of allowed frontend origins. Set to your production domain before deploying.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Shared secret between Next.js proxy and FastAPI. When set, FastAPI rejects requests missing it.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_SECRET=
# Max photo upload size in bytes (default 5 MB). Uploads over this return HTTP 413.
MAX_UPLOAD_BYTES=5242880

# ── Photo storage ───────────────────────────────────────────────────────────
# Local disk is used by default (UPLOAD_DIR). To use S3-compatible object storage
# (Cloudflare R2, Backblaze B2, Supabase Storage, AWS S3), set S3_BUCKET — its
# presence switches the backend. Local disk does NOT survive redeploys on
# Render/Fly, so set these before deploying anything you want to keep.
UPLOAD_DIR=/uploads
# S3_BUCKET=plants-photos
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com   # omit for AWS S3
# S3_REGION=auto                                                  # "auto" for R2
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# Optional: public bucket / CDN domain. If set, photos are served from this URL
# directly instead of via short-lived presigned URLs.
# S3_PUBLIC_BASE_URL=https://cdn.example.com
