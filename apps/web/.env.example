NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Tell Clerk where to send users after sign-in/sign-up, and where the sign-in page lives
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
API_INTERNAL_URL=http://localhost:8000   # use http://api:8000 in Docker
NEXT_PUBLIC_API_URL=http://localhost:8000
# Must match INTERNAL_API_SECRET in the API service. Leave blank for local dev without secret.
INTERNAL_API_SECRET=

# ── Error tracking (Sentry) ─────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN is used client-side (browser). SENTRY_DSN is server-only.
# Both can point to the same DSN. Leave blank to disable.
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/YYYY
# SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/YYYY
# Required for source map uploads at build time (get from sentry.io → Settings → Auth Tokens):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=plants-web
